datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int        @id @default(autoincrement())
  username         String     @unique
  email            String     @unique
  passwordHash     String
  createdAt        DateTime?  @default(now())
  updatedAt        DateTime?  @default(now())
  wallets          Wallet[]
  orders           Order[]
  tradesAsBuyer    Trade[]    @relation("BuyerTrades")
  tradesAsSeller   Trade[]    @relation("SellerTrades")
  transfersSent    Transfer[] @relation("SenderTransfers")
  transfersReceived Transfer[] @relation("ReceiverTransfers")
}

model Currency {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  type      String
  precision Int
  wallets   Wallet[]
  orders    Order[]
  transfers Transfer[]
}

model Wallet {
  id            Int       @id @default(autoincrement())
  userId        Int?
  currencyId    Int?
  balance       Float?    @default(0)
  frozenBalance Float?    @default(0)
  user          User?     @relation(fields: [userId], references: [id])
  currency      Currency? @relation(fields: [currencyId], references: [id])
}

model Order {
  id         Int       @id @default(autoincrement())
  userId     Int?
  currencyId Int?
  type       String?
  side       String?
  price      Float?
  amount     Float?
  status     String?
  user       User?     @relation(fields: [userId], references: [id])
  currency   Currency? @relation(fields: [currencyId], references: [id])
}

model Trade {
  id      Int    @id @default(autoincrement())
  buyerId Int?
  sellerId Int?
  price   Float?
  amount  Float?
  buyer   User?  @relation("BuyerTrades", fields: [buyerId], references: [id])
  seller  User?  @relation("SellerTrades", fields: [sellerId], references: [id])
}

model Transfer {
  id         Int       @id @default(autoincrement())
  senderId   Int?
  receiverId Int?
  currencyId Int?
  amount     Float?
  type       String?
  sender     User?     @relation("SenderTransfers", fields: [senderId], references: [id])
  receiver   User?     @relation("ReceiverTransfers", fields: [receiverId], references: [id])
  currency   Currency? @relation(fields: [currencyId], references: [id])
}