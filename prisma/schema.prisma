datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int        @id @default(autoincrement())
  username       String     @unique
  email          String     @unique
  passwordHash   String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  wallets        Wallet[]
  orders         Order[]
  tradesAsBuyer  Trade[]    @relation("BuyerTrades")
  tradesAsSeller Trade[]    @relation("SellerTrades")
  transfersSent  Transfer[] @relation("SenderTransfers")
  transfersRecv  Transfer[] @relation("RecipientTransfers")
}

model Currency {
  id        Int          @id @default(autoincrement())
  code      String       @unique
  type      CurrencyType
  precision Int          @default(2)
  wallets   Wallet[]
  orders    Order[]
  transfers Transfer[]
}

enum CurrencyType {
  FIAT
  CRYPTO
}

model Wallet {
  id            Int        @id @default(autoincrement())
  userId        Int
  currencyId    Int
  balance       Float      @default(0.0)
  frozenBalance Float      @default(0.0)
  user          User       @relation(fields: [userId], references: [id])
  currency      Currency   @relation(fields: [currencyId], references: [id])
  transfers     Transfer[]

  @@unique([userId, currencyId])
}

model Order {
  id         Int    @id @default(autoincrement())
  userId     Int
  currencyId Int
  type       String
  side       String
  price      Float
  amount     Float
  status     String @default("PENDING")
  user       User   @relation(fields: [userId], references: [id])
  currency   Currency @relation(fields: [currencyId], references: [id])
}

model Trade {
  id         Int      @id @default(autoincrement())
  orderId    Int
  buyerId    Int
  sellerId   Int
  amount     Float
  totalPrice Float
  createdAt  DateTime @default(now())
  buyer      User     @relation("BuyerTrades", fields: [buyerId], references: [id])
  seller     User     @relation("SellerTrades", fields: [sellerId], references: [id])
}

model Transfer {
  id                 Int            @id @default(autoincrement())
  senderId           Int?
  recipientId        Int?
  walletId           Int
  currencyId         Int
  amount             Float
  type               TransferType
  destinationAddress String?
  txHash             String?
  status             TransferStatus @default(SUCCESS)
  createdAt          DateTime       @default(now())
  sender             User?          @relation("SenderTransfers", fields: [senderId], references: [id])
  recipient          User?          @relation("RecipientTransfers", fields: [recipientId], references: [id])
  wallet             Wallet         @relation(fields: [walletId], references: [id])
  currency           Currency       @relation(fields: [currencyId], references: [id])
}

enum TransferType {
  INTERNAL
  EXTERNAL_DEPOSIT
  EXTERNAL_WITHDRAW
}

enum TransferStatus {
  PENDING
  SUCCESS
  FAILED
}